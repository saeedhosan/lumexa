APP_NAME="Lumexa"
APP_ENV="local"
APP_KEY=
APP_DEBUG="true"
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST="localhost"
DB_PORT=3306
DB_DATABASE=lumexa
DB_USERNAME="root"
DB_PASSWORD=

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Queue & Cache
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# Reverb (WebSocket)
BROADCAST_CONNECTION="reverb"
REVERB_APP_ID="lumexa-10001"
REVERB_APP_KEY="lumexa-key"
REVERB_APP_SECRET="lumexa-secret"
REVERB_HOST="localhost"
REVERB_PORT="8081"

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Mail (Gmail SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ENCRYPTION=tls