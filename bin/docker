#!/bin/bash

set -e

case "$1" in
  dev|development)
    echo "🚀 Starting development environment..."
    docker-compose up -d app
    echo "✅ Development server running at http://localhost:8000"
    ;;

  prod|production)
    echo "🚀 Building production environment..."
    docker-compose build --no-cache
    docker-compose up -d --scale queue=2
    echo "✅ Production running at http://localhost:8000"
    ;;

  start)
    echo "🚀 Starting all services..."
    docker-compose up -d
    echo "✅ All services running"
    ;;

  stop)
    echo "🛑 Stopping all services..."
    docker-compose down
    echo "✅ All services stopped"
    ;;

  restart)
    echo "🔄 Restarting..."
    docker-compose restart
    echo "✅ Restarted"
    ;;

  logs)
    docker-compose logs -f "${2:-app}"
    ;;

  queue)
    echo "📦 Starting queue worker..."
    docker-compose up -d queue
    echo "✅ Queue worker started"
    ;;

  migrate)
    echo "🗄️ Running migrations..."
    docker-compose exec app php artisan migrate
    echo "✅ Migrations complete"
    ;;

  seed)
    echo "🌱 Seeding database..."
    docker-compose exec app php artisan db:seed
    echo "✅ Database seeded"
    ;;

  shell)
    docker-compose exec app sh
    ;;

  test)
    docker-compose exec app php artisan test
    ;;

  *)
    echo "Usage: $0 {dev|prod|start|stop|restart|logs|queue|migrate|seed|shell|test}"
    echo ""
    echo "Commands:"
    echo "  dev         - Start development server"
    echo "  prod        - Build & start production"
    echo "  start       - Start all services"
    echo "  stop        - Stop all services"
    echo "  restart    - Restart all services"
    echo "  logs       - View logs"
    echo "  queue      - Start queue worker"
    echo "  migrate    - Run migrations"
    echo "  seed       - Seed database"
    echo "  shell      - Enter app shell"
    echo "  test       - Run tests"
    exit 1
    ;;
esac